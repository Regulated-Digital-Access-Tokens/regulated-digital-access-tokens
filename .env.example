# --- BLOCKCHAIN CONFIGURATION (Root / Hardhat) ---

# Sepolia RPC endpoint (Alchemy/Infura or other provider)
SEPOLIA_RPC_URL="https://sepolia.infura.io/v3/YOUR_PROJECT_ID"

# Private key of the deployer account (0x-prefixed)
SEPOLIA_PRIVATE_KEY="0xYOUR_PRIVATE_KEY"


# Etherscan API Key for contract verification
# Get this from etherscan.io -> My Profile -> API Keys
ETHERSCAN_API_KEY=your_etherscan_api_key_here


# --- FRONTEND CONFIGURATION (optional, can also be in frontend/.env) ---

# The deployed address of your contract after running deployment scripts
# REACT_APP_ prefix is required for Create React App
# VITE_ prefix is required if you are using Vite
VITE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
VITE_NETWORK_ID=11155111
